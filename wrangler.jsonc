{
  "name": "sightseeingroma",
  "compatibility_date": "2026-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  // Bind to the existing KV namespace (auto-provisioned on first deploy attempt)
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "542fd9aa903b438ab880c65f93db9ffe"
    }
  ]
}
