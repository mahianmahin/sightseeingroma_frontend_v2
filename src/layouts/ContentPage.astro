---
/**
 * ContentPage layout – for CMS-driven static-content pages.
 *
 * Handles:
 *  • SEO meta from the API page object
 *  • Schema.org JSON-LD injection
 *  • Banner image (from CMS or fallback)
 *  • Title / subtitle content blocks
 *  • Main body content block with template variable replacement
 *
 * Used by: about-us, terms, returnPolicy, refund, etc.
 */
import BaseLayout from './BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import { API_URL } from '@/lib/constants';

interface Props {
  /** The CMS page slug, e.g. 'about-us' */
  slug: string;
  /** Fallback page title if API has none */
  fallbackTitle: string;
  /** Fallback meta description */
  fallbackDescription?: string;
  /** Local fallback banner image path (in /public) */
  fallbackBannerImage: string;
  /** Banner overlay opacity (0–1) */
  bannerOpacity?: number;
}

const {
  slug,
  fallbackTitle,
  fallbackDescription = '',
  fallbackBannerImage,
  bannerOpacity = 0.5,
} = Astro.props;

// ── Fetch CMS data & website settings in parallel ──
let pageData: any = null;
let contentBlocks: any[] = [];
let pageImages: any[] = [];
let contactData = {
  phone: '+39 327 3633 993',
  email: 'hello@sightseeingroma.com',
  address: 'Via Antonio Fogazzaro, 5, cap–00137, Roma, Italy',
};

try {
  const [contentRes, settingsRes] = await Promise.all([
    fetch(`${API_URL}/static-content/${slug}/`),
    fetch(`${API_URL}/website-settings/`),
  ]);

  if (contentRes.ok) {
    const data = await contentRes.json();
    if (data.status === 200) {
      pageData = data.page ?? null;
      contentBlocks = data.content_blocks ?? [];
      pageImages = data.page_images ?? [];
    }
  }

  if (settingsRes.ok) {
    const settings = await settingsRes.json();
    if (settings.status === 200 && settings.data) {
      contactData = {
        phone: settings.data.website_phone_number || contactData.phone,
        email: settings.data.website_email || contactData.email,
        address: settings.data.website_address || contactData.address,
      };
    }
  }
} catch (e) {
  console.error(`[ContentPage] fetch error for ${slug}:`, e);
}

// ── Helper: find content block by unique_tag ──
function getContent(tag: string, fallback = ''): string {
  const block = contentBlocks.find((b: any) => b.unique_tag === tag && b.is_active);
  if (block?.block_content) {
    // Fix React-isms that may exist in CMS HTML
    return block.block_content
      .replace(/className=/g, 'class=')
      .replace(/htmlFor=/g, 'for=');
  }
  return fallback;
}

// ── Helper: replace {email}, {phone}, {address} placeholders ──
function replaceVars(html: string): string {
  return html
    .replace(/\{email\}/g, contactData.email)
    .replace(/\{phone\}/g, contactData.phone)
    .replace(/\{address\}/g, contactData.address);
}

// ── Helper: get CMS image by unique_tag ──
function getImageUrl(tag: string): string | null {
  const img = pageImages.find((i: any) => i.unique_tag === tag);
  if (img?.image?.file) {
    const file = img.image.file;
    return file.startsWith('http') ? file : `${API_URL}${file}`;
  }
  return null;
}

// ── SEO ──
const title = pageData?.meta_title || pageData?.title || fallbackTitle;
const description = pageData?.meta_description || fallbackDescription;
const schemaJson = pageData?.schema_json ?? null;

// ── Banner image ──
const cmsBannerTag = `${slug}-banner-image`;
const bannerImage = getImageUrl(cmsBannerTag) || fallbackBannerImage;

// ── Title / subtitle content blocks ──
const titleHtml = getContent(`${slug}-title`, `<h1 class="text-4xl font-bold">${fallbackTitle}</h1>`);
const subtitleHtml = getContent(`${slug}-subtitle`, '');

// ── Main page-content block ──
const bodyHtml = replaceVars(getContent(`${slug}-page-content`, ''));
---

<BaseLayout
  title={title}
  description={description}
  headExtra={schemaJson ? `<script type="application/ld+json">${JSON.stringify(schemaJson)}</script>` : undefined}
>
  <!-- Full-width Modern Banner -->
  <div class="relative w-full h-[45vh] min-h-[350px] flex items-center justify-center overflow-hidden">
    <div 
      class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 hover:scale-105"
      style={`background-image:url(${bannerImage})`}
    ></div>
    <!-- Elegant Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-black/20" style={`opacity: ${bannerOpacity * 1.5}`}></div>
    
    <div class="relative z-10 text-center px-6 w-full max-w-4xl mt-10">
      <div class="inline-block mb-4 px-4 py-1 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white/90 text-sm font-medium tracking-widest uppercase">
        Information
      </div>
      <div class="cms-banner-title">
        <Fragment set:html={titleHtml} />
      </div>
      {subtitleHtml && (
        <div class="cms-banner-subtitle mt-5 text-white/80 text-lg sm:text-xl font-light max-w-2xl mx-auto">
          <Fragment set:html={subtitleHtml} />
        </div>
      )}
    </div>
  </div>

  <!-- Clean, airy content section -->
  <main class="w-full bg-slate-50 border-t border-slate-200">
    <div class="container mx-auto px-4 sm:px-6 py-12 md:py-20 max-w-4xl">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sm:p-10 md:p-14 cms-content relative">
        <!-- Decorative accent -->
        <div class="absolute top-0 left-10 w-20 h-1 bg-blue-500 rounded-b-md"></div>
        
        <!-- CMS body content -->
        {bodyHtml ? (
          <div set:html={bodyHtml} />
        ) : (
          <div class="flex flex-col items-center justify-center py-20 text-slate-400">
            <svg class="w-12 h-12 mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 4v6h6"></path></svg>
            <p class="text-lg font-medium">Content is being updated</p>
          </div>
        )}

        <!-- Additional page-specific content via slot -->
        <slot />
      </div>
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* Modern Banner Typography */
  .cms-banner-title h1, .cms-banner-title h2 {
    @apply text-4xl sm:text-5xl md:text-6xl font-extrabold text-white tracking-tight leading-tight;
  }
  
  /* Modern, airy Typography for CMS Content */
  .cms-content {
    @apply text-slate-600 leading-relaxed text-[16px] sm:text-[17px] md:text-lg;
  }
  .cms-content h1 {
    @apply text-3xl sm:text-4xl font-bold text-slate-900 mb-6 mt-10 tracking-tight leading-tight;
  }
  .cms-content h2 {
    @apply text-2xl sm:text-3xl font-bold text-slate-800 mb-5 mt-10 border-b border-slate-100 pb-4 flex items-center;
  }
  .cms-content h3 {
    @apply text-xl sm:text-2xl font-semibold text-slate-800 mb-4 mt-8;
  }
  .cms-content p {
    @apply mb-6;
  }
  .cms-content a {
    @apply text-blue-600 font-medium hover:text-blue-800 underline decoration-blue-200 decoration-2 underline-offset-4 hover:decoration-blue-600 transition-all duration-300;
  }
  .cms-content ul {
    @apply list-none pl-0 mb-8 space-y-4;
  }
  .cms-content ul li {
    @apply relative pl-10;
  }
  .cms-content ul li::before {
    content: "";
    @apply absolute left-2 top-[10px] w-2.5 h-2.5 bg-blue-100 border-2 border-blue-500 rounded-full;
  }
  .cms-content ol {
    @apply list-decimal pl-5 sm:pl-8 mb-8 space-y-3 font-medium text-slate-800 marker:text-blue-500 marker:font-bold;
  }
  .cms-content ol li span {
    @apply font-normal text-slate-600;
  }
  .cms-content strong {
    @apply font-semibold text-slate-900 bg-slate-100/50 px-1 rounded-sm;
  }
  .cms-content blockquote {
    @apply border-l-4 border-blue-500 pl-6 py-4 my-8 text-slate-700 bg-blue-50/50 rounded-r-xl font-medium;
  }
  .cms-content table {
    @apply w-full mb-8 border-collapse rounded-xl overflow-hidden shadow-sm;
  }
  .cms-content th, .cms-content td {
    @apply border border-slate-200 px-4 py-3 sm:px-6 sm:py-4 text-left text-sm sm:text-base;
  }
  .cms-content th {
    @apply bg-slate-50 font-semibold text-slate-800;
  }
  .cms-content tr:nth-child(even) {
    @apply bg-slate-50/50;
  }
</style>
