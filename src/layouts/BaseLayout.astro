---
/**
 * BaseLayout.astro — replaces index.html + Main.jsx
 *
 * Renders the full HTML shell with:
 *   • SEO meta tags (title, description, og, canonical)
 *   • Global CSS
 *   • Google Fonts (non-render-blocking)
 *   • GTM (deferred)
 *   • Dynamic head code from API (global_head_code)
 *   • Navbar + Footer (will become Astro components)
 *   • Toast container for React islands
 */
import '../styles/global.css';
import { getGlobalHeadCode, getWebsiteSettings } from '../lib/api';
import Navbar from '../components/Navbar/Navbar.astro';
import Footer from '../components/Footer/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  /** Extra head content (structured data, etc.) */
  headExtra?: string;
}

const {
  title = 'Sightseeing Roma – Rome Hop-On Hop-Off Bus Tours & Tickets',
  description = 'Discover Rome with Sightseeing Roma - Your trusted partner for Rome tours and tickets. Compare top hop-on hop-off buses, book online, and explore the Eternal City.',
  canonicalUrl,
  ogImage = '/Banner/hero-banner.webp',
  headExtra = '',
} = Astro.props;

// Fetch server-side data in parallel
let globalHeadCode = '';
let websiteSettings: any = {};
try {
  const [headCodeRes, settingsRes] = await Promise.all([
    getGlobalHeadCode().catch(() => null),
    getWebsiteSettings().catch(() => null),
  ]);
  if (headCodeRes?.status === 200 && headCodeRes?.global_head_code) {
    globalHeadCode = headCodeRes.global_head_code;
  }
  if (settingsRes?.status === 200 && settingsRes?.data) {
    websiteSettings = settingsRes.data;
  }
} catch {
  // Fail silently — layout still renders with defaults
}

const siteUrl = 'https://www.sightseeingroma.com';
const canonical = canonicalUrl || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Sightseeing Roma" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />

  <!-- Preconnect to API -->
  <link rel="preconnect" href="https://api.sightseeingroma.com" crossorigin />
  <link rel="dns-prefetch" href="https://api.sightseeingroma.com" />

  <!-- DNS prefetch for third-party services -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />

  <!-- Google Fonts: Inter (non-render-blocking) -->
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" />
  </noscript>

  <meta name="google-site-verification" content="TRkJt8R3GlrYMY7woPFKA0FNS7EXoPee3ZvfiJAH1rQ" />

  <!-- Global head code from server (analytics, structured data, etc.) -->
  <Fragment set:html={globalHeadCode} />

  <!-- Per-page extra head content -->
  <Fragment set:html={headExtra} />

  <!-- GTM (deferred until after load) -->
  <script is:inline>
    window.addEventListener('load', function() {
      setTimeout(function() {
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-TR9XMH8W');
      }, 100);
    });
  </script>
</head>

<body>
  <!-- GTM (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TR9XMH8W"
      height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>

  <!-- Navbar -->
  <Navbar />

  <!-- Page content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <Footer />
</body>
</html>
