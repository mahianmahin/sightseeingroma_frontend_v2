---
/**
 * /compare-tickets — Ticket comparison page
 *
 * Strategy: SSR (prerender = false) — fetches live package data.
 * Duration filter uses query param for zero-JS filtering via full page navigation.
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { API_URL } from '@/lib/constants';

// ── Fetch all packages ──
let packages: any[] = [];
try {
  const res = await fetch(`${API_URL}/packages/`);
  if (res.ok) {
    const data = await res.json();
    packages = data.bus_data || [];
  }
} catch (e) {
  console.error('[CompareTickets] fetch error:', e);
}

// ── Filter by duration via query param ──
const url = new URL(Astro.request.url);
const selectedDuration = url.searchParams.get('duration') || 'all';

const durations = ['all', ...new Set(packages.map((pkg: any) => pkg.ticket_type).filter(Boolean))];
const filteredPackages = selectedDuration === 'all'
  ? packages
  : packages.filter((pkg: any) => pkg.ticket_type === selectedDuration);
const recommendedPackages = packages.filter((pkg: any) => pkg.is_featured).slice(0, 4);

const mediaBase = API_URL;

function filterUrl(duration: string): string {
  if (duration === 'all') return '/compare-tickets';
  return `/compare-tickets?duration=${encodeURIComponent(duration)}`;
}

// Group packages by company for mobile view
const byCompany: Record<string, any[]> = {};
for (const pkg of filteredPackages) {
  const key = pkg.company || 'Other';
  if (!byCompany[key]) byCompany[key] = [];
  byCompany[key].push(pkg);
}
---

<BaseLayout
  title="Compare Bus Tour Tickets | Sightseeing Roma"
  description="Compare hop-on hop-off bus tour tickets in Rome. Find the best price, duration, and features for your Rome adventure."
>
  <div class="min-h-screen bg-gray-50 pt-16">
    <!-- Hero -->
    <div class="bg-[#930B31] text-white py-16 md:py-20">
      <div class="container mx-auto px-4">
        <h1 class="text-3xl md:text-5xl font-bold text-center mb-4">Compare Bus Tour Tickets</h1>
        <p class="text-center text-lg md:text-xl opacity-90 max-w-3xl mx-auto">
          Find the perfect ticket for your Rome adventure. Compare features, prices, and durations.
        </p>
      </div>
    </div>

    <!-- Filter -->
    <div class="container mx-auto px-4 -mt-8">
      <div class="bg-white rounded-lg shadow-lg p-4 md:p-6">
        <div class="flex flex-wrap gap-3 justify-center">
          {durations.map((duration: string) => (
            <a
              href={filterUrl(duration)}
              class={`px-4 md:px-6 py-2 rounded-full font-semibold text-sm md:text-base transition-all duration-200 no-underline ${
                selectedDuration === duration
                  ? 'bg-[#930B31] text-white shadow-md'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
              }`}
            >
              {duration === 'all' ? 'All Tickets' : duration.toUpperCase()}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="container mx-auto px-4 py-12">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8 text-gray-800">Tickets At A Glance</h2>

      <!-- Desktop Table -->
      <div class="hidden lg:block overflow-x-auto bg-white rounded-lg shadow-lg">
        <table class="w-full">
          <thead class="bg-[#930B31] text-white">
            <tr>
              <th class="px-6 py-4 text-left font-semibold">Ticket Name</th>
              <th class="px-6 py-4 text-center font-semibold">Company</th>
              <th class="px-6 py-4 text-center font-semibold">Duration</th>
              <th class="px-6 py-4 text-center font-semibold">Adult Price</th>
              <th class="px-6 py-4 text-center font-semibold">Youth Price</th>
              <th class="px-6 py-4 text-center font-semibold">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {filteredPackages.map((pkg: any, index: number) => (
              <tr class={`${index % 2 === 0 ? 'bg-gray-50' : 'bg-white'} hover:bg-blue-50 transition-colors`}>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div>
                      <p class="font-semibold text-gray-900">{pkg.title}</p>
                      <p class="text-sm text-gray-500">{pkg.type}</p>
                    </div>
                    {pkg.is_featured && (
                      <span class="bg-[#FAD502] text-[#930B31] text-xs font-bold px-2 py-1 rounded">FEATURED</span>
                    )}
                  </div>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-block px-3 py-1 bg-gray-100 rounded-full text-sm font-medium text-gray-700 capitalize">{pkg.company}</span>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="font-semibold text-[#930B31]">{pkg.duration}</span>
                </td>
                <td class="px-6 py-4 text-center">
                  <div class="flex flex-col items-center">
                    <span class="text-lg font-bold text-gray-900">€{pkg.adult_price}</span>
                    {pkg.off_price > pkg.adult_price && (
                      <span class="text-sm text-gray-400 line-through">€{pkg.off_price}</span>
                    )}
                  </div>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="text-lg font-bold text-gray-900">€{pkg.youth_price}</span>
                </td>
                <td class="px-6 py-4 text-center">
                  <a
                    href={`/manageBookings/E9/${pkg.package_tag}`}
                    class="inline-block bg-[#930B31] text-white px-4 py-2 rounded-md text-sm font-semibold hover:bg-red-800 transition-colors no-underline"
                  >
                    View
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile Table -->
      <div class="lg:hidden overflow-x-auto bg-white rounded-lg shadow-lg">
        <table class="w-full text-left border-collapse">
          <thead class="bg-[#930B31] text-white sticky top-0">
            <tr>
              <th class="px-2 py-2 text-[10px] font-semibold uppercase tracking-wide">Ticket</th>
              <th class="px-2 py-2 text-[10px] font-semibold uppercase tracking-wide text-center">Dur.</th>
              <th class="px-2 py-2 text-[10px] font-semibold uppercase tracking-wide text-center">Adult</th>
              <th class="px-2 py-2 text-[10px] font-semibold uppercase tracking-wide text-center">Youth</th>
              <th class="px-2 py-2 text-[10px] font-semibold uppercase tracking-wide text-center">Buy</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(byCompany).map(([company, pkgs]) => (
              <Fragment>
                <tr class="bg-[#FAD502]/20 border-t-2 border-[#930B31]">
                  <td colspan="5" class="px-2 py-1.5">
                    <span class="text-[10px] font-bold text-[#930B31] uppercase tracking-widest">{company}</span>
                  </td>
                </tr>
                {(pkgs as any[]).map((pkg: any, i: number) => (
                  <tr class={`${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'} border-b border-gray-100`}>
                    <td class="px-2 py-2 max-w-[120px]">
                      <p class="text-[11px] font-semibold text-gray-900 leading-tight line-clamp-2">{pkg.title}</p>
                      {pkg.is_featured && (
                        <span class="inline-block mt-0.5 bg-[#FAD502] text-[#930B31] text-[8px] font-bold px-1 rounded leading-tight">FEATURED</span>
                      )}
                    </td>
                    <td class="px-2 py-2 text-center whitespace-nowrap">
                      <span class="text-[10px] font-semibold text-[#930B31]">{pkg.duration}</span>
                    </td>
                    <td class="px-2 py-2 text-center">
                      <span class="text-[11px] font-bold text-gray-900">€{pkg.adult_price}</span>
                      {pkg.off_price > pkg.adult_price && (
                        <span class="block text-[9px] text-gray-400 line-through">€{pkg.off_price}</span>
                      )}
                    </td>
                    <td class="px-2 py-2 text-center">
                      <span class="text-[11px] font-bold text-gray-900">€{pkg.youth_price}</span>
                    </td>
                    <td class="px-2 py-2 text-center">
                      <a
                        href={`/manageBookings/E9/${pkg.package_tag}`}
                        class="inline-block bg-[#930B31] text-white px-2 py-1 rounded text-[10px] font-semibold hover:bg-red-800 transition-colors whitespace-nowrap no-underline"
                      >
                        View
                      </a>
                    </td>
                  </tr>
                ))}
              </Fragment>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recommended Packages -->
    {recommendedPackages.length > 0 && (
      <div class="bg-gray-100 py-16">
        <div class="container mx-auto px-4">
          <h2 class="text-2xl md:text-3xl font-bold text-center mb-4 text-gray-800">Recommended Packages</h2>
          <p class="text-center text-gray-600 mb-10 max-w-2xl mx-auto">
            Our most popular and highly-rated tour packages, chosen by thousands of satisfied customers
          </p>
          <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6">
            {recommendedPackages.map((pkg: any) => (
              <a
                href={`/manageBookings/E9/${pkg.package_tag}`}
                class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 group block no-underline"
              >
                <div class="relative overflow-hidden h-36 md:h-48">
                  {pkg.thumbnail_large_webp ? (
                    <img
                      src={`${mediaBase}${pkg.thumbnail_large_webp}`}
                      alt={pkg.thumbnail_large_alt || pkg.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                      loading="lazy"
                      width="400"
                      height="250"
                    />
                  ) : pkg.thumbnail_large ? (
                    <img
                      src={`${mediaBase}${pkg.thumbnail_large}`}
                      alt={pkg.thumbnail_large_alt || pkg.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                      loading="lazy"
                      width="400"
                      height="250"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-[#930B31] to-[#FAD502]"></div>
                  )}
                  {pkg.is_featured && (
                    <span class="absolute top-2 right-2 bg-[#FAD502] text-[#930B31] text-xs font-bold px-2 py-1 rounded">FEATURED</span>
                  )}
                </div>
                <div class="p-3 md:p-4">
                  <h3 class="font-bold text-gray-900 text-sm md:text-base mb-1 line-clamp-2">{pkg.title}</h3>
                  <p class="text-xs text-gray-500 mb-2">{pkg.type} · {pkg.duration}</p>
                  <div class="flex items-center gap-2">
                    <span class="text-lg font-bold text-[#930B31]">€{pkg.adult_price}</span>
                    {pkg.off_price > pkg.adult_price && (
                      <span class="text-sm text-gray-400 line-through">€{pkg.off_price}</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>
</BaseLayout>
