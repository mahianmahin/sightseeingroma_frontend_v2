---
/**
 * Homepage — Phase 1 placeholder
 * Will be fully built in Phase 3 with server-side data fetching.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sightseeing Roma – Rome Hop-On Hop-Off Bus Tours & Tickets"
  description="Compare top hop-on hop-off bus tours in Rome. Book Big Bus, City Sightseeing, Green Line & more. Best prices guaranteed. Explore the Eternal City your way!"
>
  <section class="min-h-screen flex items-center justify-center bg-gray-50">
    <div class="text-center px-4">
      <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-4">
        🏛️ Sightseeing Roma
      </h1>
      <p class="text-lg md:text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Astro migration in progress — Phase 1 scaffold complete.
        <br />
        The full homepage with SSG data will be built in Phase 3.
      </p>
      <div class="inline-flex items-center gap-2 bg-green-100 text-green-800 px-4 py-2 rounded-full text-sm font-medium">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        Astro dev server running
      </div>
    </div>
  </section>
</BaseLayout>
