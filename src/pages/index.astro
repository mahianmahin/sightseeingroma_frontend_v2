---
/**
 * Homepage — SSR (server-rendered on every request)
 *
 * All API data is fetched server-side on each request and rendered into HTML.
 * This ensures editors always see fresh featured offers, prices, and cards
 * without needing a rebuild.
 *
 * Interactive sections (Services tabs, SectionNav scroll spy) are React islands.
 * Display-only sections (FeaturedToday, PromoBanner, RecommendedServices, HeroFeaturedOffer)
 * are pure Astro components — zero JS shipped.
 *
 * Performance target: FCP < 0.5s, LCP < 1s (hero image)
 */
export const prerender = false; // SSR — fresh data on every request

import BaseLayout from '../layouts/BaseLayout.astro';

// Astro components — zero JS
import Hero from '../components/Home/Hero.astro';
import WhyBook from '../components/Home/WhyBook.astro';
import FinalCTA from '../components/Home/FinalCTA.astro';
import Work from '../components/Home/Work.astro';
import Contact from '../components/Home/Contact.astro';
import CustomerReviews from '../components/Home/CustomerReviews.astro';
import FeaturedTodayAstro from '../components/Home/FeaturedToday.astro';
import PromoBannerAstro from '../components/Home/PromoBanner.astro';
import RecommendedServicesAstro from '../components/Home/RecommendedServices.astro';

// React islands — only truly interactive components
import SectionNav from '../Components/SectionNav/SectionNav';
import Services from '../Components/Services/Services';

// ─── Server-side data fetching (runs on every request) ───────────────
// All API calls run in PARALLEL to minimize TTFB.
// Data is passed as props to child components (they no longer fetch internally).
import { getFeaturedOffers, getFeaturedOffersByPackage, getPackages, getCards, getReviews, getWebsiteSettings } from '../lib/api';

const [
  featuredOffersResult,
  offersByPackageResult,
  packagesResult,
  cardsResult,
  reviewsResult,
  settingsResult,
] = await Promise.allSettled([
  getFeaturedOffers(),
  getFeaturedOffersByPackage(),
  getPackages(),
  getCards(),
  getReviews(),
  getWebsiteSettings(),
]);

// ─── Extract featured offers → bestOffer ─────────────────────────────
let bestOffer: any = null;
try {
  const res = featuredOffersResult.status === 'fulfilled' ? featuredOffersResult.value : null;
  const offers = res?.status === 200 && res?.data?.length ? res.data : [];
  const withDiscount = offers
    .filter((o: any) => o.original_adult_price && o.offer_adult_price && parseFloat(o.original_adult_price) > parseFloat(o.offer_adult_price))
    .map((o: any) => ({
      ...o,
      discountPct: Math.round(((parseFloat(o.original_adult_price) - parseFloat(o.offer_adult_price)) / parseFloat(o.original_adult_price)) * 100)
    }));
  if (withDiscount.length) {
    withDiscount.sort((a: any, b: any) => b.discountPct - a.discountPct);
    bestOffer = withDiscount[0];
  }
} catch (err) {
  console.error('Failed to process featured offers:', err);
}

// ─── Extract packages data → for Services island ─────────────────────
const packagesData = packagesResult.status === 'fulfilled' ? packagesResult.value : null;
const initialBusData = packagesData?.bus_data || [];
const initialFolders = packagesData?.folders || [];

// ─── Extract offers-by-package → for Services Card badges ────────────
const obpRes = offersByPackageResult.status === 'fulfilled' ? offersByPackageResult.value : null;
const initialOffersByPackage = (obpRes?.status === 200) ? (obpRes.data || {}) : {};

// ─── Extract cards → for RecommendedServices ─────────────────────────
const cardsData = cardsResult.status === 'fulfilled' ? cardsResult.value : null;

// ─── Extract reviews → for CustomerReviews ───────────────────────────
const reviewsData = reviewsResult.status === 'fulfilled' ? reviewsResult.value : [];

// ─── Extract settings → for Contact ──────────────────────────────────
const settingsRes = settingsResult.status === 'fulfilled' ? settingsResult.value : null;

// Cache headers are managed by ISR middleware (src/middleware.ts).
// No need to set Cache-Control here — the middleware handles HIT/STALE/MISS logic.
---

<BaseLayout
  title="Sightseeing Roma – Rome Hop-On Hop-Off Bus Tours & Tickets"
  description="Compare top hop-on hop-off bus tours in Rome. Book Big Bus, City Sightseeing, Green Line & more. Best prices guaranteed. Explore the Eternal City your way!"
>
  <!-- Hero — static HTML + background image (LCP element) + server-rendered featured offer -->
  <Hero bestOffer={bestOffer} />

  <!-- Section Navigation — React island for scroll spy + sticky behavior -->
  <SectionNav client:visible />

  <!-- Tickets Section — React island for tabs, filters, card interactions -->
  <!-- Initial data passed as props to skip client-side /packages/ and /featured-offers/by-package/ fetches -->
  <div id="tickets">
    <Services
      client:idle
      initialBusData={initialBusData}
      initialFolders={initialFolders}
      initialOffersByPackage={initialOffersByPackage}
    />
  </div>

  <!-- FeaturedToday — desktop only, server-rendered (zero JS) -->
  <div class="hidden lg:block">
    <FeaturedTodayAstro bestOffer={bestOffer} />
  </div>

  <!-- Why Book With Us — pure Astro, zero JS -->
  <div id="why-us">
    <WhyBook />
  </div>

  <!-- CTA Banner — pure Astro, zero JS -->
  <FinalCTA />

  <!-- Customer Reviews — server-fetched, CSS-only carousel -->
  <CustomerReviews reviews={reviewsData} />

  <!-- PromoBanner — server-rendered (zero JS), uses same pre-fetched data -->
  <PromoBannerAstro bestOffer={bestOffer} />

  <!-- Live Rome Your Way — server-rendered (zero JS), uses pre-fetched cards -->
  <div id="explore">
    <RecommendedServicesAstro cardsData={cardsData} />
  </div>

  <!-- The Process — pure Astro, zero JS -->
  <div id="features">
    <Work />
  </div>

  <!-- Contact — server-fetched contact data, zero JS -->
  <div id="routes">
    <Contact settingsData={settingsRes} />
  </div>
</BaseLayout>
