---
/**
 * 404 — Page Not Found
 * Pure static, zero JS.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
---

<BaseLayout title="Page Not Found – Sightseeing Roma" description="The page you're looking for doesn't exist.">
  <div class="container mx-auto">
    <PageBanner imageMd="/images/404-banner.webp" opacity={0.5}>
      <h1 class="text-4xl font-bold">Page Not Found</h1>
      <p class="text-lg mt-2">Oops! The page you are looking for does not exist.</p>
    </PageBanner>

    <div class="flex flex-col items-center justify-center py-12 px-4">
      <div class="text-center max-w-2xl">
        <h2 class="text-6xl font-bold text-red-800 mb-4">404</h2>
        <p class="text-xl text-gray-600 mb-8">
          We couldn't find the page you were looking for. The page might have been removed,
          renamed, or doesn't exist.
        </p>
        <div class="space-y-4">
          <a
            href="/"
            class="inline-block bg-red-800 text-white px-8 py-3 rounded-lg hover:bg-red-900 transition-colors duration-300"
          >
            Return to Home
          </a>
          <p class="text-gray-500 text-sm mt-4">
            Need help? <a href="/about-us" class="text-red-800 hover:underline">Contact us</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
