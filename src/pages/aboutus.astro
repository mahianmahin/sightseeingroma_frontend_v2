---
/**
 * /aboutus → redirect to /about-us
 * Preserves backward-compatible URL using meta-refresh (works in static SSG).
 */
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url=/about-us" />
    <link rel="canonical" href="/about-us" />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href="/about-us">/about-us</a>…</p>
  </body>
</html>
