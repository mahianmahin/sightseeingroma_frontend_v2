---
/**
 * Contact.astro — "Get In Touch" section. Zero JavaScript.
 * Contact data fetched at build time from /website-settings/.
 */
import { getWebsiteSettings } from '../../lib/api';

let contactData = {
  phone: '+39 327 3633 993',
  email: 'hello@sightseeingroma.com',
  address: "Piazza d'Ara Coeli,8, 00186, roma",
  mapLink: 'https://maps.app.goo.gl/5tippW2iGzJ7h8TY7',
};

try {
  const res = await getWebsiteSettings().catch(() => null);
  if (res?.status === 200 && res?.data) {
    contactData = {
      phone: res.data.website_phone_number || contactData.phone,
      email: res.data.website_email || contactData.email,
      address: res.data.website_address || contactData.address,
      mapLink: res.data.address_map_link || contactData.mapLink,
    };
  }
} catch {}
---

<div class="relative w-full bg-white overflow-hidden">
  <div class="container mx-auto px-4 py-8 lg:py-16">
    <div class="flex flex-col-reverse lg:flex-row items-center gap-8 lg:gap-16">

      <!-- Content Section -->
      <div class="w-full lg:w-1/2">
        <div class="text-center lg:text-left mb-8">
          <p class="py-2 my-4 text-2xl font-bold border-b-4 border-yellow-500 inline-block text-yellow-500">Get In Touch</p>
          <h2 class="text-lg md:text-3xl font-bold mb-2 text-[#930B31]">From Comfort to Budget, Explore Ticket Options for Every Traveler</h2>
          <p class="text-gray-600 mb-4">Seamless booking, diverse routes, and flexible schedules at your fingertips</p>
        </div>

        <div class="grid gap-4">
          <!-- Phone -->
          <a
            href={`tel:${contactData.phone}`}
            class="group flex items-center gap-4 p-4 rounded-xl bg-gray-50 hover:bg-white border border-gray-100 hover:border-[#FAD502] hover:shadow-md transition-all duration-300"
          >
            <div class="w-12 h-12 rounded-full bg-[#930B31] text-white flex items-center justify-center text-xl group-hover:scale-110 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="flex-1">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-0.5">Call Us</p>
              <p class="text-[#930B31] font-bold text-sm md:text-base">{contactData.phone}</p>
            </div>
          </a>

          <!-- Email -->
          <a
            href={`mailto:${contactData.email}`}
            class="group flex items-center gap-4 p-4 rounded-xl bg-gray-50 hover:bg-white border border-gray-100 hover:border-[#FAD502] hover:shadow-md transition-all duration-300"
          >
            <div class="w-12 h-12 rounded-full bg-[#930B31] text-white flex items-center justify-center text-xl group-hover:scale-110 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="flex-1">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-0.5">Email Us</p>
              <p class="text-[#930B31] font-bold text-sm md:text-base break-all md:break-normal">{contactData.email}</p>
            </div>
          </a>

          <!-- Address -->
          <a
            href={contactData.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 p-4 rounded-xl bg-gray-50 hover:bg-white border border-gray-100 hover:border-[#FAD502] hover:shadow-md transition-all duration-300"
          >
            <div class="w-12 h-12 rounded-full bg-[#930B31] text-white flex items-center justify-center text-xl group-hover:scale-110 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3" fill="white"/></svg>
            </div>
            <div class="flex-1">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-0.5">Visit Us</p>
              <p class="text-[#930B31] font-bold text-sm md:text-base">{contactData.address}</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Image Section -->
      <div class="w-full lg:w-1/2">
        <div class="overflow-hidden">
          <img src="/images/get-in-touch.webp" alt="Get in touch with Sightseeing Roma" width="800" height="520" class="w-full h-auto object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</div>
