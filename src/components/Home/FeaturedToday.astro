---
/**
 * FeaturedToday.astro — Server-rendered "Featured Today" section.
 * Replaces the React island FeaturedToday.jsx.
 * Data is passed as props from the parent page (fetched at build time).
 * Zero JS shipped — pure HTML + Tailwind CSS.
 */

export interface Props {
  bestOffer: {
    id: number;
    offer_title?: string;
    offer_description?: string;
    badge_text?: string;
    offer_adult_price: string;
    original_adult_price?: string;
    offer_image_url?: string;
    offer_image_webp_url?: string;
    company_name?: string;
    time_remaining?: number;
    discountPct: number;
  } | null;
}

const { bestOffer } = Astro.props;

// Don't render if no valid offer
if (!bestOffer) return null;

const API_URL = 'https://api.sightseeingroma.com';

const {
  id,
  offer_title,
  offer_description,
  badge_text,
  offer_adult_price,
  original_adult_price,
  offer_image_url,
  offer_image_webp_url,
  company_name,
  time_remaining,
  discountPct,
} = bestOffer;

// Format countdown timer
function formatTimeRemaining(seconds?: number): string | null {
  if (!seconds || seconds <= 0) return null;
  const days = Math.floor(seconds / 86400);
  const hours = Math.floor((seconds % 86400) / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  if (days > 0) return `${days}d ${hours}h`;
  if (hours > 0) return `${hours}h ${minutes}m`;
  return `${minutes}m`;
}

const timeLabel = formatTimeRemaining(time_remaining);

const imageUrl = offer_image_url
  ? (offer_image_url.startsWith('http') ? offer_image_url : `${API_URL}${offer_image_url}`)
  : '/placeholder.jpg';
const imageWebpUrl = offer_image_webp_url
  ? (offer_image_webp_url.startsWith('http') ? offer_image_webp_url : `${API_URL}${offer_image_webp_url}`)
  : undefined;

const showStrike = original_adult_price && parseFloat(original_adult_price) > parseFloat(offer_adult_price);
---

<section id="featured-today" class="py-10 md:py-20 bg-gradient-to-br from-gray-50 to-gray-100 relative overflow-hidden">
  {/* Background decoration */}
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
    <div class="absolute top-[-10%] right-[-5%] w-[300px] md:w-[500px] h-[300px] md:h-[500px] bg-yellow-200/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-[300px] md:w-[500px] h-[300px] md:h-[500px] bg-red-200/20 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    {/* Heading */}
    <div class="text-center mb-8 md:mb-12">
      <div class="inline-block relative">
        <h2 class="text-2xl md:text-4xl lg:text-5xl font-black text-gray-900 mb-3 relative z-10">
          Featured Today: Best Deal Right Now
        </h2>
        <div class="absolute bottom-1 md:bottom-2 left-0 w-full h-2 md:h-3 bg-[#FAD502]/40 -skew-x-12 -z-0 rounded-sm"></div>
      </div>
    </div>

    {/* Main Feature Card */}
    <div class="max-w-6xl mx-auto">
      <div class="bg-white rounded-2xl md:rounded-3xl shadow-xl md:shadow-2xl overflow-hidden border-2 border-[#FAD502] ring-4 ring-[#FAD502]/20 flex flex-col md:flex-row transform transition-all duration-300 hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.15)] hover:ring-[#FAD502]/40 group">
        
        {/* LEFT: IMAGE */}
        <div class="w-full md:w-[45%] relative aspect-[4/3] md:aspect-auto md:min-h-[450px] overflow-hidden">
          {imageWebpUrl ? (
            // <picture>
            //   <source srcset={imageWebpUrl} type="image/webp" />
            // </picture>
            <img
              src={imageUrl}
              alt={offer_title || 'Featured offer'}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              width="600"
              height="450"
              loading="lazy"
            />
          ) : (
            <img
              src={imageUrl}
              alt={offer_title || 'Featured offer'}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              width="600"
              height="450"
              loading="lazy"
            />
          )}

          {/* BADGES */}
          <div class="absolute top-0 left-0 flex flex-col items-start z-20">
            {/* Featured Today Ribbon */}
            <div class="bg-[#930B31] text-white text-xs md:text-sm font-bold py-1.5 md:py-2 pl-3 md:pl-4 pr-4 md:pr-6 uppercase tracking-wide shadow-lg">
              {badge_text || 'Featured Today'}
            </div>
            
            {/* Discount Tag */}
            {discountPct > 0 && (
              <div class="bg-[#FAD502] text-gray-900 font-bold px-3 md:px-4 py-2 md:py-3 mt-2 ml-2 md:ml-3 rounded shadow-lg flex flex-col items-center justify-center">
                <span class="text-lg md:text-xl font-black leading-none">{discountPct}%</span>
                <span class="text-[9px] md:text-[10px] font-semibold uppercase tracking-wider mt-0.5">OFF</span>
              </div>
            )}
          </div>
        </div>

        {/* RIGHT: CONTENT */}
        <div class="w-full md:w-[55%] p-5 md:p-10 lg:p-12 flex flex-col justify-center relative bg-white">
          {/* Decorative Icon Background */}
          <div class="absolute top-6 right-6 opacity-[0.03] pointer-events-none hidden md:block">
            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="currentColor"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7" stroke="white" stroke-width="2"/></svg>
          </div>

          {/* Timer */}
          {timeLabel && (
            <div class="flex items-center gap-2 mb-3 md:mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-[#930B31]"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm4.2 14.2L11 13V7h1.5v5.2l4.5 2.7-.8 1.3z"/></svg>
              <span class="text-sm text-gray-600">Ends in:</span>
              <span class="text-sm font-bold text-[#930B31]">{timeLabel}</span>
            </div>
          )}

          {/* Company */}
          {company_name && (
            <p class="text-xs md:text-sm text-gray-500 uppercase tracking-wide mb-1">{company_name}</p>
          )}

          <h3 class="text-xl md:text-2xl lg:text-3xl font-bold text-gray-900 mb-3 md:mb-5 leading-tight">
            {offer_title}
          </h3>
          
          <div class="text-gray-600 text-base md:text-lg mb-4 md:mb-6 leading-relaxed line-clamp-3">
            {offer_description}
          </div>

          {/* Price */}
          <div class="flex items-baseline gap-3 mb-5 md:mb-8">
            <span class="text-3xl md:text-4xl font-black text-[#930B31]">
              €{offer_adult_price}
            </span>
            {showStrike && (
              <span class="text-lg md:text-xl text-gray-400 line-through">
                €{original_adult_price}
              </span>
            )}
            <span class="text-sm text-gray-500">per person</span>
          </div>

          <div class="mt-auto">
            <a 
              href={`/featured-offers?highlight=${id}`}
              class="w-full bg-[#930B31] hover:bg-[#7a0929] text-white text-base md:text-lg font-bold py-3.5 md:py-4 px-8 md:px-10 rounded-lg md:rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-3 group/btn"
            >
              View Offer
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/btn:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
