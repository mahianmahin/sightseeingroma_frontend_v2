---
/**
 * Hero.astro — Server-rendered hero section.
 * Background image via CSS, text + trust signals + CTA buttons all in static HTML.
 * Mobile: Shows server-rendered HeroFeaturedOffer (zero JS).
 * Desktop: Shows trust card.
 *
 * CLS fix: content is fully server-rendered, no client-side layout shifts.
 */
import HeroFeaturedOffer from './HeroFeaturedOffer.astro';

export interface Props {
  bestOffer?: any;
}

const { bestOffer = null } = Astro.props;
---

<section class="w-full relative min-h-[85vh] md:min-h-[90vh] flex items-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero.webp"
      alt="Rome Sightseeing"
      class="w-full h-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black" style="opacity:0.70"></div>
  </div>

  <div class="container mx-auto px-4 z-10 py-12 md:py-0">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

      <!-- Left Column (60%) -->
      <div class="w-full lg:w-[60%] text-white text-center lg:text-left">

        <!-- H1 Heading -->
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.2] mb-6 drop-shadow-lg">
          Book Rome Sightseeing Tickets With Confidence
        </h1>

        <!-- Subheading -->
        <p class="text-base sm:text-lg md:text-xl text-gray-100 mb-8 max-w-2xl mx-auto lg:mx-0 font-medium drop-shadow-md">
          Hop-on hop-off buses, Vatican &amp; Colosseum tickets, and top Rome experiences — all from trusted operators.
        </p>

        <!-- Trust Signals -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-x-6 gap-y-3 mb-10 text-sm md:text-base font-medium text-gray-100">
          <div class="flex items-center gap-2">
            <div class="flex text-[#FAD502]">
              <!-- 5 stars -->
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="opacity-70"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <span>4.6/5 Traveler Rating</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#FAD502]"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm-1.177-7.86l-2.765-2.767L6.645 12.8l4.178 4.178 6.96-6.96-1.413-1.415-5.547 5.537z"/></svg>
            <span>Verified Operators</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#FAD502]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Secure Payments</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#FAD502]"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <span>Instant Confirmation</span>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
          <a
            href="#tickets"
            class="w-full sm:w-auto bg-[#930B31] hover:bg-[#7a0926] text-white font-bold py-3.5 px-8 rounded-lg transition-all transform hover:scale-105 shadow-lg text-base md:text-lg uppercase tracking-wide text-center"
          >
            Explore Rome Tickets
          </a>

          <div class="relative w-full sm:w-auto group">
            <div class="absolute -inset-1 bg-[#FAD502] rounded-lg blur opacity-40 animate-pulse transition duration-1000 group-hover:opacity-70 group-hover:duration-200"></div>
            <a
              href="/featured-offers"
              class="relative w-full sm:w-auto bg-[#FAD502] text-[#930B31] font-bold py-3.5 px-8 rounded-lg transition-all transform hover:scale-[1.02] text-base md:text-lg shadow-xl flex items-center justify-center gap-2"
            >
              <span>Today's Featured Offer</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-bounce"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right Column (40%) - Trust Card (desktop) / Featured Offer (mobile) -->
      <div class="w-full lg:w-[40%] flex justify-center lg:justify-end">
        <!-- Mobile: Show server-rendered featured offer card (zero JS) -->
        <div class="lg:hidden w-full flex justify-center">
          {bestOffer && <HeroFeaturedOffer bestOffer={bestOffer} />}
        </div>
        <!-- Desktop: Show trust card -->
        <div class="hidden lg:block bg-white text-gray-800 rounded-xl shadow-2xl p-5 md:p-6 max-w-md w-full transform hover:scale-[1.02] transition-transform duration-300">
          <div class="flex items-center gap-3 mb-4 border-b border-gray-100 pb-4">
            <div class="bg-[#FAD502]/20 p-2.5 rounded-full text-[#FAD502] shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <div>
              <div class="font-bold text-lg text-gray-900">Excellent</div>
              <div class="text-xs text-gray-600">Trusted by travelers worldwide</div>
            </div>
          </div>

          <div class="space-y-2">
            <div class="flex items-center gap-3 group p-1.5 rounded-lg hover:bg-gray-50 transition-colors">
              <div class="bg-gray-100 p-2 rounded-lg text-gray-600 group-hover:bg-[#930B31] group-hover:text-white transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M1 6h22v12H1z M4 6V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v2"/></svg>
              </div>
              <span class="font-medium text-sm text-gray-700 group-hover:text-gray-900 transition-colors">Hop-on Hop-off Tours</span>
            </div>
            <div class="flex items-center gap-3 group p-1.5 rounded-lg hover:bg-gray-50 transition-colors">
              <div class="bg-gray-100 p-2 rounded-lg text-gray-600 group-hover:bg-[#930B31] group-hover:text-white transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2 20h20L12 4z"/></svg>
              </div>
              <span class="font-medium text-sm text-gray-700 group-hover:text-gray-900 transition-colors">Colosseum &amp; Vatican</span>
            </div>
            <div class="flex items-center gap-3 group p-1.5 rounded-lg hover:bg-gray-50 transition-colors">
              <div class="bg-gray-100 p-2 rounded-lg text-gray-600 group-hover:bg-[#930B31] group-hover:text-white transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v2a3 3 0 0 0 0 6v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2a3 3 0 0 0 0-6V7zm11-2v2h-2V5h2zm0 12v2h-2v-2h2zm0-6v2h-2v-2h2z"/></svg>
              </div>
              <span class="font-medium text-sm text-gray-700 group-hover:text-gray-900 transition-colors">Skip-the-Line Access</span>
            </div>
          </div>

          <div class="mt-5 pt-4 border-t border-gray-100 text-center">
            <p class="text-[10px] text-gray-400 mb-2 uppercase tracking-wider font-semibold">Official Partner of</p>
            <div class="flex justify-center gap-4 opacity-60 grayscale hover:grayscale-0 transition-all duration-300">
              <span class="font-bold text-gray-700 text-xs">Big Bus</span>
              <span class="font-bold text-gray-700 text-xs">City Sightseeing</span>
              <span class="font-bold text-gray-700 text-xs">I Love Rome</span>
            </div>
          </div>
        </div> <!-- end hidden lg:block trust card wrapper -->
      </div>

    </div>
  </div>
</section>
