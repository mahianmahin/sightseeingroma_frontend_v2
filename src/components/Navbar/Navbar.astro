---
/**
 * Navbar.astro — Server-rendered navigation bar
 *
 * Desktop: Pure HTML links (zero JS) with a React island for auth buttons.
 * Mobile:  React island for hamburger menu + auth-aware navigation.
 *
 * This replaces the old fully-client Navbar.jsx and eliminates:
 *   - react-router-dom Link/useNavigate
 *   - deferredFetch for nav data
 *   - Suspense/lazy EditPanelSheet (deferred to admin pages)
 */
import MobileNav from './MobileNav';
import DesktopAuthNav from './DesktopAuthNav';
---

<nav class="navbar bg-2 sticky top-0 text-white z-50 backdrop-blur-sm shadow-lg border-b border-white/10">
  <!-- ═══ Mobile navbar (< lg) ═══ -->
  <div class="lg:hidden w-full flex items-center justify-between px-2">
    <!-- React island: hamburger + dropdown (only loaded on mobile) -->
    <div class="flex items-center gap-1" id="mobile-nav-mount">
      <MobileNav client:media="(max-width: 1023px)" />
    </div>

    <!-- Mobile right-side actions -->
    <div class="flex items-center space-x-3">
      <a href="/compare-tickets" aria-label="Buy tickets"
         class="font-bold bg-1 hover:bg-yellow-600 rounded-lg p-2.5 transition-colors duration-200 flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
      </a>
      <!-- Auth-dependent mobile icons are inside MobileNav React island -->
    </div>
  </div>

  <!-- ═══ Desktop navbar (≥ lg) ═══ -->
  <div class="hidden lg:flex container mx-auto w-full items-center justify-between">
    <!-- Logo -->
    <a href="/">
      <img src="/Logo.webp" alt="Sightseeing Roma - Rome tour booking" width="160" height="85" class="w-16 md:w-36 pl-0 md:pl-5" />
    </a>

    <!-- Nav links -->
    <ul class="menu menu-horizontal px-1 font-medium text-lg text-white flex items-center space-x-2" aria-label="Main navigation">
      <li>
        <a href="/" class="hover:bg-white/10 rounded-lg px-4 py-2 transition-all duration-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Home
        </a>
      </li>

      <!-- Static links (always visible for logged-out users; auth island handles swap) -->
      <li data-auth="guest">
        <a href="/about-us" class="hover:bg-white/10 rounded-lg px-4 py-2 transition-all duration-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          About Us
        </a>
      </li>

      <li>
        <a href="/agentpoints" class="hover:bg-white/10 rounded-lg px-4 py-2 transition-all duration-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          Agent Points
        </a>
      </li>

      <li>
        <a href="/blogs" class="hover:bg-white/10 rounded-lg px-4 py-2 transition-all duration-200 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
          Blog
        </a>
      </li>

      <!-- Buy Tickets CTA -->
      <li class="ml-4">
        <a href="/company-packages/big-bus" class="font-bold bg-1 hover:bg-yellow-600 rounded-lg px-4 py-3 transition-colors duration-200 flex items-center gap-2 text-black">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
          Buy Tickets
        </a>
      </li>

      <!-- Auth buttons — React island (desktop) -->
      <DesktopAuthNav client:idle />
    </ul>
  </div>
</nav>
